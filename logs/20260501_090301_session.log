### Fichier 1 — `routes/admin.js` (ajout après le GET /)

```javascript
// ── S2-2 : Création tombola ──────────────────────────────────────────

router.get('/tombola/new', isAuthenticated, (req, res) => {
  res.render('admin/form', {
    title: 'Nouvelle tombola',
    tombola: null,
    lots: [{ name: '' }],
    errors: [],
    flash: null
  });
});

router.post('/tombola/new', isAuthenticated, (req, res) => {
  const name = (req.body.name || '').trim();
  const starts_at = req.body.starts_at || '';
  const ends_at   = req.body.ends_at   || '';
  const raw  = req.body['lots[]'];
  const lots = (Array.isArray(raw) ? raw : raw ? [raw] : [])
    .map(l => l.trim()).filter(Boolean);

  const errors = [];
  if (!name) errors.push('Le nom est requis.');
  else if (name.length > 255) errors.push('Le nom ne doit pas dépasser 255 caractères.');
  if (!starts_at) errors.push('La date de début est requise.');
  if (!ends_at)   errors.push('La date de fin est requise.');
  if (starts_at && ends_at && new Date(starts_at) >= new Date(ends_at))
    errors.push('La date de début doit être antérieure à la date de fin.');
  if (lots.length === 0) errors.push('Au moins un lot est requis.');

  if (errors.length > 0) {
    return res.render('admin/form', {
      title: 'Nouvelle tombola',
      tombola: { name, starts_at, ends_at },
      lots: lots.map((n, i) => ({ name: n, position: i + 1 })),
      errors, flash: null
    });
  }

  const insertTombola  = db.prepare(`INSERT INTO tombolas (name, starts_at, ends_at, status) VALUES (?, ?, ?, 'pending')`);
  const insertLot      = db.prepare(`INSERT INTO lots (tombola_id, name, position) VALUES (?, ?, ?)`);
  const insertDraw     = db.prepare(`INSERT INTO draw_state (tombola_id, phase) VALUES (?, 'idle')`);

  const create = db.transaction((name, starts_at, ends_at, lots) => {
    const { lastInsertRowid: tombola_id } = insertTombola.run(name, starts_at, ends_at);
    lots.forEach((lotName, i) => insertLot.run(tombola_id, lotName, i + 1));
    insertDraw.run(tombola_id);
    return tombola_id;
  });

  const id = create(name, starts_at, ends_at, lots);
  req.session.flash = { type: 'success', message: 'Tombola créée avec succès.' };
  res.redirect(`/admin/tombola/${id}/edit`);
});
```

