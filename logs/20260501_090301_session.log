### Fichier 2 — `views/admin/form.ejs` (création)

```html
<%- include('../layout') %>
<div class="page-header">
  <h1><%= tombola && tombola.id ? 'Modifier la tombola' : 'Nouvelle tombola' %></h1>
  <a href="/admin" class="btn">← Retour</a>
</div>

<% if (errors && errors.length > 0) { %>
<div class="alert alert-error">
  <ul><% errors.forEach(e => { %><li><%= e %></li><% }); %></ul>
</div>
<% } %>

<form method="POST"
      action="<%= tombola && tombola.id ? '/admin/tombola/' + tombola.id + '/edit' : '/admin/tombola/new' %>"
      class="form-card">

  <div class="form-group">
    <label for="name">Nom de la tombola *</label>
    <input type="text" id="name" name="name" maxlength="255" required
           value="<%= tombola ? tombola.name : '' %>" class="form-control">
  </div>

  <div class="form-group">
    <label for="image">Image (JPEG, PNG, WebP — max 2 Mo)</label>
    <input type="file" id="image" name="image"
           accept="image/jpeg,image/png,image/webp" class="form-control">
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="starts_at">Date de début *</label>
      <input type="datetime-local" id="starts_at" name="starts_at" required
             value="<%= tombola && tombola.starts_at ? String(tombola.starts_at).replace(' ','T').slice(0,16) : '' %>"
             class="form-control">
    </div>
    <div class="form-group">
      <label for="ends_at">Date de fin *</label>
      <input type="datetime-local" id="ends_at" name="ends_at" required
             value="<%= tombola && tombola.ends_at ? String(tombola.ends_at).replace(' ','T').slice(0,16) : '' %>"
             class="form-control">
    </div>
  </div>

  <div class="form-group">
    <label>Lots <small>(premier = gros lot — glisser pour réordonner)</small></label>
    <div id="lots-container">
      <% (lots && lots.length ? lots : [{ name: '' }]).forEach(function(lot) { %>
      <div class="lot-row" draggable="true">
        <span class="drag-handle">⠿</span>
        <input type="text" name="lots[]" value="<%= lot.name %>"
               placeholder="Nom du lot" required class="form-control">
        <button type="button" class="btn btn-sm btn-danger lot-remove">×</button>
      </div>
      <% }); %>
    </div>
    <button type="button" id="add-lot" class="btn btn-secondary">+ Ajouter un lot</button>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">
      <%= tombola && tombola.id ? 'Enregistrer' : 'Créer la tombola' %>
    </button>
    <a href="/admin" class="btn">Annuler</a>
  </div>
</form>
</main>
<script src="/js/admin-form.js"></script>
</body>
</html>
